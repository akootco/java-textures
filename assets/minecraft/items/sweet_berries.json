          {"threshold": 0, "model": {"type": "model", "model": "edulis:item/blueberries"}},
          {"threshold": 16, "model": {"type": "model", "model": "edulis:item/blueberries/bite1"}},
          {"threshold": 24, "model": {"type": "model", "model": "edulis:item/blueberries/bite2"}}]}},

        {"threshold": 3, "model": {"type": "range_dispatch", "property": "use_duration", "entries": [
          {"threshold": 0, "model": {"type": "model", "model": "edulis:item/peas"}},
