          {"threshold": 16, "model": {"type": "model", "model": "edulis:item/red_grapes/bite1"}},
          {"threshold": 24, "model": {"type": "model", "model": "edulis:item/red_grapes/bite2"}}]}},

        {"threshold": 8, "model": {"type": "range_dispatch", "property": "use_duration", "entries": [
