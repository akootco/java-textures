          {"threshold": 0, "model": {"type": "model", "model": "edulis:item/lemons"}},
          {"threshold": 16, "model": {"type": "model", "model": "edulis:item/lemons/bite1"}},
          {"threshold": 24, "model": {"type": "model", "model": "edulis:item/lemons/bite2"}}]}},

