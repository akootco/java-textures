{
  "model": {
    "type": "select",
    "property": "custom_model_data",
    "cases": [
      {"when": "blackberries", "model": {"type": "range_dispatch", "property": "use_duration", "entries": [
            {"threshold": 0, "model": {"type": "model", "model": "edulis:item/blackberries"}},
            {"threshold": 16, "model": {"type": "model", "model": "edulis:item/blackberries/bite1"}},
            {"threshold": 24, "model": {"type": "model", "model": "edulis:item/blackberries/bite2"}}]}}
    ],
    "fallback": {
      "type": "range_dispatch", "property": "custom_model_data",
      "fallback": {"type": "model", "model": "item/sweet_berries"},
      "entries": [
        {"threshold": 1, "model": {"type": "range_dispatch", "property": "use_duration", "entries": [
          {"threshold": 0, "model": {"type": "model", "model": "edulis:item/strawberries"}},
          {"threshold": 16, "model": {"type": "model", "model": "edulis:item/strawberries/bite1"}},
          {"threshold": 24, "model": {"type": "model", "model": "edulis:item/strawberries/bite2"}}]}},

