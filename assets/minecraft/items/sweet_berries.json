          {"threshold": 16, "model": {"type": "model", "model": "edulis:item/limes/bite1"}},
          {"threshold": 24, "model": {"type": "model", "model": "edulis:item/limes/bite2"}}]}},

        {"threshold": 6, "model": {"type": "range_dispatch", "property": "use_duration", "entries": [
          {"threshold": 0, "model": {"type": "model", "model": "edulis:item/yoyle_berry"}},
          {"threshold": 16, "model": {"type": "model", "model": "edulis:item/yoyle_berry/bite1"}},
          {"threshold": 24, "model": {"type": "model", "model": "edulis:item/yoyle_berry/bite2"}}]}},

        {"threshold": 7, "model": {"type": "range_dispatch", "property": "use_duration", "entries": [
