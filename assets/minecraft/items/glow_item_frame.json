{
  "model": {
    "type": "select",
    "property": "custom_model_data",
    "fallback": {"type": "model", "model": "item/glow_item_frame"},
    "cases": [
      {"when": "oak_cutting_board", "model": {"type": "model", "model": "edulis:block/cutting_board/oak"}},
      {"when": "dark_oak_cutting_board", "model": {"type": "model", "model": "edulis:block/cutting_board/dark_oak"}},
      {"when": "pale_oak_cutting_board", "model": {"type": "model", "model": "edulis:block/cutting_board/pale_oak"}},
      {"when": "spruce_cutting_board", "model": {"type": "model", "model": "edulis:block/cutting_board/spruce"}},
      {"when": "acacia_cutting_board", "model": {"type": "model", "model": "edulis:block/cutting_board/acacia"}},
      {"when": "jungle_cutting_board", "model": {"type": "model", "model": "edulis:block/cutting_board/jungle"}},
      {"when": "bamboo_cutting_board", "model": {"type": "model", "model": "edulis:block/cutting_board/bamboo"}},
      {"when": "cherry_cutting_board", "model": {"type": "model", "model": "edulis:block/cutting_board/cherry"}},
      {"when": "mangrove_cutting_board", "model": {"type": "model", "model": "edulis:block/cutting_board/mangrove"}},
      {"when": "birch_cutting_board", "model": {"type": "model", "model": "edulis:block/cutting_board/birch"}},
      {"when": "warped_cutting_board", "model": {"type": "model", "model": "edulis:block/cutting_board/warped"}},
      {"when": "crimson_cutting_board", "model": {"type": "model", "model": "edulis:block/cutting_board/crimson"}}
    ]
  }
}